# masterbuilder-bot environment
# Copy this file to .env and fill in what you have.
# The bot works with NO keys at all (template drafts) — add a key when you
# want real AI-written drafts.

# ---- LLM provider ----------------------------------------------------------
# Leave LLM_PROVIDER blank to auto-detect from whichever key is set:
#   ANTHROPIC_API_KEY -> anthropic (Claude)
#   OPENAI_API_KEY    -> openai
#   LLM_BASE_URL      -> openai_compatible (Ollama / LM Studio on the Mac mini)
# Or force one: anthropic | openai | openai_compatible
LLM_PROVIDER=

# Optional model override. Defaults: claude-opus-4-8 / gpt-4o-mini / llama3.1
LLM_MODEL=

# For local models via an OpenAI-compatible server, e.g. Ollama:
#   LLM_BASE_URL=http://localhost:11434/v1
LLM_BASE_URL=

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Bot behavior ----------------------------------------------------------
# draft_only | approved_posting
# draft_only is the safe default. The bot will never post in draft_only mode.
BOT_MODE=draft_only

BRAND_NAME=masterbuilder.ai
TIMEZONE=America/New_York

# ---- Buttondown (the weekly email newsletter) ------------------------------
# Free up to 100 subscribers. API key: buttondown.com -> Settings -> API.
# Username is your buttondown.com/<username> — powers the site's subscribe box.
# Set BUTTONDOWN_DRAFT_ONLY=true to approve each email on Buttondown by hand.
BUTTONDOWN_API_KEY=
BUTTONDOWN_USERNAME=
BUTTONDOWN_DRAFT_ONLY=

# ---- X / Twitter keys — retired from auto-posting. Leave blank. ------------
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
